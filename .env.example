# Etsy API (register at https://developers.etsy.com)
ETSY_API_KEY=your_keystring
ETSY_SHARED_SECRET=your_shared_secret

# Facebook (https://developers.facebook.com)
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token
FB_AD_ACCOUNT_ID=act_your_ad_account_id

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Etsy shop name
ETSY_SHOP_NAME=Drakey3DPrints
